<idea-plugin>
    <id>com.baize.agent</id>
    <name>Baize</name>
    <vendor>Baize Team</vendor>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <toolWindow
            id="Baize"
            anchor="right"
            icon="/icons/baize.svg"
            factoryClass="com.baize.BaizeToolWindowFactory"/>
    </extensions>

    <actions>
        <action
            id="Baize.ExplainCode"
            class="com.baize.actions.ExplainCodeAction"
            text="Baize: Explain Code"
            description="Ask Baize to explain the selected code">
            <add-to-group group-id="EditorPopupMenu" anchor="first"/>
        </action>
    </actions>
</idea-plugin>
