{
  "name": "baize-vscode",
  "displayName": "Baize",
  "version": "0.1.0",
  "description": "Baize AI Coding Assistant — VSCode Extension",
  "main": "./dist/extension.js",
  "engines": {
    "vscode": "^1.90.0"
  },
  "activationEvents": [
    "onView:baize.chat"
  ],
  "contributes": {
    "commands": [
      {
        "command": "baize.openChat",
        "title": "Baize: Open Chat"
      },
      {
        "command": "baize.explainCode",
        "title": "Baize: Explain Code"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "baize",
          "title": "Baize",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "baize": [
        {
          "type": "webview",
          "id": "baize.chat",
          "name": "Chat"
        }
      ]
    }
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -watch"
  },
  "devDependencies": {
    "@types/vscode": "^1.90.0",
    "typescript": "^5.5.0"
  }
}
