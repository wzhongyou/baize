# Baize 模型配置示例
# 复制为 llmgate.toml，填入你的 API key。
#
# 两种配置方式：
#   1. 直接写入 key：  key = "sk-xxx"
#   2. 环境变量引用：  key = "${DEEPSEEK_KEY}"  （推荐）
#
# 使用：
#   export DEEPSEEK_KEY=sk-xxx
#   ./baize

# ── 供应商（取消注释你要用的） ─────────────────────────────
[[providers]]
name = "deepseek"
key = "${DEEPSEEK_KEY}"
# default_model = "deepseek-chat"      # 可选：指定默认模型

# [[providers]]
# name = "openai"
# key = "${OPENAI_KEY}"
#
# [[providers]]
# name = "anthropic"
# key = "${ANTHROPIC_KEY}"
#
# [[providers]]
# name = "glm"
# key = "${GLM_KEY}"

# ── 路由策略（可选） ──────────────────────────────────────────
[strategy]
primary = "deepseek"
# fallback = ["glm"]
